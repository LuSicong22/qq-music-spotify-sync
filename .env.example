# Spotify Developer App credentials
# Create at: https://developer.spotify.com/dashboard
SPOTIPY_CLIENT_ID=your_spotify_client_id
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret

# Optional: override redirect URI (must match what's set in Spotify Developer App)
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Obtained by running: python scripts/get_refresh_token.py
SPOTIFY_REFRESH_TOKEN=your_refresh_token

# Optional: set after first run to skip playlist lookup next time
SPOTIFY_PLAYLIST_ID=

# Playlist display name (created if no managed playlist found)
SPOTIFY_PLAYLIST_NAME=QQ音乐热歌榜

# QQ Music chart ID (26 = 热歌榜)
QQ_MUSIC_TOP_ID=26

# Number of songs to sync (max 100)
QQ_MUSIC_NUM=100

# Optional: Telegram notification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
